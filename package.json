{
  "name": "financial-ai-agents",
  "version": "1.0.0",
  "description": "Financial AI Agents system for stock analysis",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
